PORT=5001
CLIENT_URL=http://localhost:5173
# Tùy chọn: chỉ bật khi bạn muốn ép Node dùng DNS công cộng để tra SRV Atlas.
MONGODB_DNS_SERVERS=1.1.1.1,8.8.8.8

# Chỉ dùng một trong các cấu hình MongoDB bên dưới.
# Cách 1: URI Atlas dạng SRV, yêu cầu máy hiện tại phân giải được DNS/SRV.
MONGODB_CONNECTIONSTRING=mongodb+srv://<db_user>:<db_password>@<cluster-host>/?appName=<app-name>

# MongoDB Atlas dạng node trực tiếp, lấy từ DNS thật của cluster.
MONGODB_DIRECT_CONNECTIONSTRING=your_mongodb_connection_string_here

ACCESS_TOKEN_SECRET=your_access_token_secret_here

CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name_here
CLOUDINARY_API_KEY=your_cloudinary_api_key_here
CLOUDINARY_API_SECRET=your_cloudinary_api_secret_here

GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_CALLBACK_URL=http://localhost:5001/api/auth/google/callback

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_smtp_username_here
SMTP_PASS=your_smtp_app_password_here
MAIL_FROM=your_mail_from_here
