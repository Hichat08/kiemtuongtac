PORT=5001
CLIENT_URL=http://localhost:5173
# Tùy chọn: chỉ bật khi bạn muốn ép Node dùng DNS công cộng để tra SRV Atlas.
# MONGODB_DNS_SERVERS=1.1.1.1,8.8.8.8

# Chỉ dùng một trong các cấu hình MongoDB bên dưới.
# Cách 1: URI Atlas dạng SRV, yêu cầu máy hiện tại phân giải được DNS/SRV.
MONGODB_CONNECTIONSTRING=mongodb+srv://<db_user>:<db_password>@<cluster-host>/?appName=<app-name>

# Cách 2: URI Atlas dạng node trực tiếp, dùng khi SRV lookup bị chặn.
MONGODB_DIRECT_CONNECTIONSTRING=mongodb://<db_user>:<db_password>@<host1>:27017,<host2>:27017/<db_name>?replicaSet=<replica-set>&authSource=admin

# Cách 3: MongoDB chạy local.
MONGODB_URI=mongodb://localhost:27017/<db_name>


ACCESS_TOKEN_SECRET=<generate-a-long-random-secret>

CLOUDINARY_CLOUD_NAME=<your-cloudinary-cloud-name>
CLOUDINARY_API_KEY=<your-cloudinary-api-key>
CLOUDINARY_API_SECRET=<your-cloudinary-api-secret>

GOOGLE_CLIENT_ID=<your-google-client-id>
GOOGLE_CLIENT_SECRET=<your-google-client-secret>
GOOGLE_CALLBACK_URL=http://localhost:5001/api/auth/google/callback

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=<your-smtp-username>
SMTP_PASS=<your-smtp-app-password>
MAIL_FROM=Kiem Tuong Tac <noreply@example.com>
